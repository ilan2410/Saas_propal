1.5 px-1 pb-1.5 mb-1.5 border-b border-teal-200\">\n                            <RefreshCw className=\"w-3.5 h-3.5 text-teal-600 shrink-0\" />\n                            <span className=\"text-xs font-medium text-teal-700\">\n                              {getBoucleHeaderText(group.boucleLeader!, questions)} ÔÇö groupe &quot;{group.boucleId}&quot;\n                            </span>\n                          </div>\n                          <div className=\"space-y-1\">\n                            {group.items.map(({ treeItem: { q, depth }, idx }) => renderItem(q, depth, idx))}\n                          </div>\n                        </div>\n                      );\n                    }\n                    const { treeItem: { q, depth }, idx } = group.items[0];\n                    return renderItem(q, depth, idx);\n                  })}\n                </div>\n\n                <div className=\"flex gap-2 mt-2\">\n                  <Tooltip text=\"Ouvre le constructeur de questions pour cr├®er une nouvelle question SP pour ce template.\">\n                    <Button\n                      size=\"sm\"\n                      variant=\"outline\"\n                      onClick={() => {\n                        setBuilderQuestionTitle('');\n                        setBuildingForTemplate(t.id);\n                      }}\n                      className=\"flex-1\"\n                    >\n                      <Plus className=\"w-4 h-4 mr-2\" />\n                      Ajouter\n                    </Button>\n                  </Tooltip>\n                  <Tooltip text=\"Supprimer d├®finitivement toutes les questions de ce workflow.\">\n                    <Button\n                      size=\"sm\"\n                      variant=\"outline\"\n                      onClick={() => deleteAllQuestions(t.id, t.nom)}\n                      disabled={questions.length === 0}\n                      className=\"border-red-200 text-red-500 hover:bg-red-50 hover:border-red-300 hover:text-red-600 disabled:opacity-40\"\n                    >\n                      <Trash2 className=\"w-4 h-4 mr-2\" />\n                      Tout supprimer\n                    </Button>\n                  </Tooltip>\n                  <Tooltip text=\"T├®l├®charge une sauvegarde JSON compl├¿te de ce workflow.\">\n                    <Button\n                      size=\"sm\"\n                      variant=\"outline\"\n                      onClick={() => exportWorkflow(t.id, t.nom)}\n                      disabled={questions.length === 0}\n                      className=\"border-sky-200 text-sky-700 hover:bg-sky-50 hover:border-sky-300 disabled:opacity-40\"\n                    >\n                      <Download className=\"w-4 h-4 mr-2\" />\n                      Exporter\n                    </Button>\n                  </Tooltip>\n                  <Tooltip text=\"Restaure un workflow depuis une sauvegarde JSON. Le workflow actuel sera remplac├® apr├¿s confirmation.\">\n                    <Button\n                      size=\"sm\"\n                      variant=\"outline\"\n                      onClick={() => importWorkflow(t.id, t.nom)}\n                      className=\"border-slate-200 text-slate-700 hover:bg-slate-50 hover:border-slate-300\"\n                    >\n                      <Upload className=\"w-4 h-4 mr-2\" />\n                      Importer\n                    </Button>\n                  </Tooltip>\n                  {questions.length === 0 ? (\n                    SHOW_SP_AI_APPEND_EDIT && (\n                      <Tooltip text=\"D├®cris ton workflow en langage naturel et l'IA g├®n├¿re les questions SP automatiquement.\">\n                        <Button\n                          size=\"sm\"\n                          variant=\"outline\"\n                          onClick={() => setAiGeneratingForTemplate({ templateId: t.id, mode: 'create' })}\n                          className=\"flex-1 border-violet-200 text-violet-700 hover:bg-violet-50 hover:border-violet-300\"\n                        >\n                          <Sparkles className=\"w-4 h-4 mr-2\" />\n                          G├®n├®rer IA\n                        </Button>\n                      </Tooltip>\n                    )\n                  ) : (\n                    <>\n                      {SHOW_SP_AI_APPEND_EDIT && (\n                        <>\n                          <Tooltip text=\"Ajoute de nouvelles questions avec l'IA sans modifier le workflow existant.\">\n                            <Button\n                              size=\"sm\"\n                              variant=\"outline\"\n                              onClick={() => setAiGeneratingForTemplate({ templateId: t.id, mode: 'append' })}\n                              className=\"flex-1 border-violet-200 text-violet-700 hover:bg-violet-50 hover:border-violet-300\"\n                            >\n                              <Sparkles className=\"w-4 h-4 mr-2\" />\n                              Ajouter IA\n                            </Button>\n                          </Tooltip>\n                          <Tooltip text=\"Modifie le workflow complet avec l'IA. Cette action remplacera le workflow apr├¿s validation.\">\n                            <Button\n                              size=\"sm\"\n                              variant=\"outline\"\n                              onClick={() => setAiGeneratingForTemplate({ templateId: t.id, mode: 'modify' })}\n                              className=\"flex-1 border-orange-200 text-orange-700 hover:bg-orange-50 hover:border-orange-300\"\n                            >\n                              <Sparkles className=\"w-4 h-4 mr-2\" />\n                              Modifier IA\n                            </Button>\n                          </Tooltip>\n                        </>\n                      )}\n                    </>\n                  )}\n                  <Tooltip text=\"Simule le formulai
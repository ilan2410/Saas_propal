gth; i++) {\r\n      const p = products[i];\r\n      const rowNum = i + 1;\r\n\r\n      // Basic Validation\r\n      if (!p.nom) {\r\n        errors.push(`Ligne ${rowNum}: Nom manquant`);\r\n        continue;\r\n      }\r\n\r\n      // Clean/Normalize data\r\n      const categorie = validCategories.includes(p.categorie?.toLowerCase()) \r\n        ? p.categorie.toLowerCase() \r\n        : 'autre';\r\n      \r\n      const type_frequence = p.type_frequence === 'unique' ? 'unique' : 'mensuel';\r\n      const mode_fas = p.mode_fas === 'multiplie_par_quantite' ? 'multiplie_par_quantite' : 'fixe_par_selection';\r\n\r\n      // Parse numbers\r\n      const prix_mensuel = p.prix_mensuel ? parseFloat(String(p.prix_mensuel).replace(',', '.')) : null;\r\n      const prix_vente = p.prix_vente ? parseFloat(String(p.prix_vente).replace(',', '.')) : null;\r\n      const prix_installation = p.prix_installation ? parseFloat(String(p.prix_installation).replace(',', '.')) : null;\r\n      const engagement_mois = p.engagement_mois ? parseInt(String(p.engagement_mois)) : null;\r\n\r\n      // Tags\r\n      const tags = typeof p.tags === 'string' \r\n        ? p.tags.split(',').map((t: string) => t.trim()).filter(Boolean)\r\n        : [];\r\n\r\n      try {\r\n        const { error } = await supabase.from('catalogues_produits').insert({\r\n          organization_id: isGlobalImport ? null : user.id,\r\n          nom: p.nom,\r\n          categorie,\r\n          description: p.description || null,\r\n          fournisseur: p.fournisseur || null,\r\n          type_frequence,\r\n          mode_fas,\r\n          prix_mensuel,\r\n          prix_vente,\r\n          prix_installation,\r\n          engagement_mois,\r\n          image_url: p.image_url || null,\r\n          tags,\r\n          caracteristiques: {}, // Default empty\r\n          est_produit_base: false,\r\n          actif: true\r\n        });\r\n\r\n        if (error) {\r\n          errors.push(`Ligne ${rowNum}: ${error.message}`);\r\n        } else {\r\n          successCount++;\r\n        }\r\n      } catch (err) {\r\n        errors.push(`Ligne ${rowNum}: Erreur serveur`);\r\n      }\r\n    }\r\n\r\n    return NextResponse.json({ success: true, count: successCount, errors });\r\n\r\n  } catch (error) {\r\n    return NextResponse.json({ error: 'Erreur lors de l\\'importation' }, { status: 500 });\r\n  }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ilan\\CascadeProjects\\Saas_propal\\app\\api\\catalogue\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ilan\\CascadeProjects\\Saas_propal\\app\\api\\debug\\credits\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ilan\\CascadeProjects\\Saas_propal\\app\\api\\debug\\organizations\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ilan\\CascadeProjects\\Saas_propal\\app\\api\\onboarding\\complete\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ilan\\CascadeProjects\\Saas_propal\\app\\api\\onboarding\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ilan\\CascadeProjects\\Saas_propal\\app\\api\\propositions\\[id]\\clone-site\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Us